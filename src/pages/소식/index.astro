---
// 2026-07-21 최종 디자인 반영 — 데스크톱 table + 좁은 화면 mobile-list.
// 2026-07-21 — 기관 필터 탭은 이제 network-orgs에 등록된 기관 전체를 항상 보여준다
// (글 수와 무관 — 태그가 자유 문자열이 아니라 관리되는 컬렉션이 됐기 때문).
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoticeList from '../../components/NoticeList.astro';
import { sortForList, 태그경로 } from '../../lib/notices';
import { filterableOrgs } from '../../lib/networkOrgs';

const notices = sortForList(await getCollection('notices'));
const filterOrgs = await filterableOrgs();
---

<BaseLayout pageName="소식">
  <section>
    <small class="review">검토 영역: 소식 게시판</small>
    <h1>소식</h1>
    {filterOrgs.length > 0 && (
      <nav aria-label="소식 기관 분류">
        <ul class="tabs">
          <li><a href="/소식/" aria-current="page">전체</a></li>
          {filterOrgs.map((org) => (
            <li><a href={태그경로(org.id)}>{org.data.name}</a></li>
          ))}
        </ul>
      </nav>
    )}
    <NoticeList notices={notices} variant="table" empty="아직 소식이 없습니다." />
  </section>
</BaseLayout>

<style>
  .tabs {
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    list-style: none;
    display: flex;
  }
  .tabs a {
    border: 1px solid var(--line);
    background: #fff;
    align-items: center;
    min-height: 2.5rem;
    padding: 0.3rem 0.75rem;
    display: inline-flex;
  }
  .tabs a[aria-current='page'] {
    border-bottom: 0.3rem solid var(--green);
    font-weight: 900;
  }
</style>
