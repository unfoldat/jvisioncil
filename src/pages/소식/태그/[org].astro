---
// 방사의 실행 지점. 태그 = 정적 페이지. 소식이 1건이라도 있는 기관 + 좋은비전(후원안내가 항상 링크)만 생성.
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NoticeList from '../../../components/NoticeList.astro';
import { sortForList, orgCounts } from '../../../lib/notices';
import { SITE_NAME } from '../../../config';

export async function getStaticPaths() {
  const notices = await getCollection('notices');
  const orgs = [...new Set([SITE_NAME, ...orgCounts(notices).keys()])];

  return orgs.map((org) => ({
    params: { org },
    props: { org, notices: sortForList(notices.filter((n) => n.data.org.includes(org))) },
  }));
}

const { org, notices } = Astro.props;
---

<BaseLayout pageName={`${org} 소식`}>
  <section>
    <small class="review">검토 영역: 소식 게시판</small>
    <h1>{org} 소식</h1>
    <p><a href="/소식/">소식 전체 목록</a></p>
    <NoticeList notices={notices} variant="table" empty={`${org} 소식은 아직 없습니다.`} />
  </section>
</BaseLayout>
