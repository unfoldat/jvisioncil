---
// 방사의 실행 지점. 태그 = 정적 페이지. network-orgs에 등록된 기관 전체에 대해
// 페이지를 만든다(글 0건이어도) — 필터 탭이 항상 유효한 목적지로 이어지도록.
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NoticeList from '../../../components/NoticeList.astro';
import { sortForList } from '../../../lib/notices';

export async function getStaticPaths() {
  const notices = await getCollection('notices');
  const orgs = await getCollection('network-orgs');

  return orgs.map((org) => ({
    params: { org: org.id },
    props: {
      orgName: org.data.name,
      notices: sortForList(notices.filter((n) => n.data.org.id === org.id)),
    },
  }));
}

const { orgName, notices } = Astro.props;
---

<BaseLayout pageName={`${orgName} 소식`}>
  <section>
    <small class="review">검토 영역: 소식 게시판</small>
    <h1>{orgName} 소식</h1>
    <p><a href="/소식/">소식 전체 목록</a></p>
    <NoticeList notices={notices} variant="table" empty={`${orgName} 소식은 아직 없습니다.`} />
  </section>
</BaseLayout>
