---
// url 없는 글 = 우리가 원본(활동소식) → 내부 상세.
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { noticeOrgDisplay } from '../../lib/notices';
import { orgMap } from '../../lib/networkOrgs';

export async function getStaticPaths() {
  const allNotices = await getCollection('notices');
  const internalNotices = allNotices.filter(({ data }) => !data.url);
  return internalNotices.map((notice) => ({ params: { slug: notice.id }, props: { notice } }));
}

const { notice } = Astro.props;
const { Content } = await render(notice);
const { name: orgName, url: orgUrl } = noticeOrgDisplay(notice, await orgMap());
const isoDate = notice.data.date.toISOString().slice(0, 10);
---

<BaseLayout pageName={notice.data.title}>
  <article>
    <section class="post-head">
      <small class="review">검토 영역: 소식 상세정보</small>
      <p>
        {orgUrl ? (
          <a class="tag" href={orgUrl} target="_blank" rel="noopener noreferrer">
            {orgName}<span class="sr-only">, 공식 사이트, 새 창에서 열림</span>
          </a>
        ) : (
          <span class="tag">{orgName}</span>
        )}
      </p>
      <h1>{notice.data.title}</h1>
      <p class="meta">
        {orgName} · <time datetime={isoDate} data-pagefind-meta="date[datetime]">{isoDate}</time>
      </p>
    </section>
    <section>
      <h2>본문</h2>
      <Content />
    </section>
    <p><a href="/소식/">소식 목록으로 돌아가기</a></p>
  </article>
</BaseLayout>
