---
// 검색 착지 페이지. header 검색창(Enter) → 여기로 GET ?q=.
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout pageName="검색 결과" searchable={false}>
  <section>
    <small class="review">검토 영역: 검색 결과</small>
    <h1>검색 결과</h1>
    <p id="search-status" role="status">검색어를 입력해 주세요.</p>

    {/* Pagefind는 "서울필로스합창단"처럼 띄어쓰기 없는 복합어를 통째로 한 토큰으로
        인덱싱해 "필로스"같은 부분 문자열은 못 찾는다(Pagefind 자체의 알려진 한계).
        기관명·소식 제목은 이 두 목록에서 부분 문자열로 따로 찾아 보여준다. */}
    <div id="org-matches" hidden>
      <h2>기관</h2>
      <ul id="org-results"></ul>
    </div>

    <div id="notice-matches" hidden>
      <h2>관련 소식</h2>
      <ul id="notice-results"></ul>
    </div>

    <div id="page-matches" hidden>
      <h2>관련 페이지</h2>
      <ul id="page-results"></ul>
    </div>
  </section>

  {/* BaseLayout의 <slot/> 안(= <main> 내부)에 있어야 한다. */}
  <script is:inline>
    // is:inline 필수 — is:inline을 빼면 Astro/Vite가 이 dynamic import를
    // __vitePreload로 감싸면서 __VITE_PRELOAD__ 참조 에러를 내며 실제로 깨짐
    // (실측 확인, ReferenceError: __VITE_PRELOAD__ is not defined).
    // CSP script-src는 이 스크립트의 정확한 해시(scripts/inject-csp.mjs가 빌드마다
    // 자동 계산)로 허용하므로 is:inline이어도 'unsafe-inline' 없이 안전하게 통과한다.
    (async () => {
      const params = new URLSearchParams(window.location.search);
      const q = (params.get('q') || '').trim();
      const status = document.getElementById('search-status');
      const box = document.getElementById('site-search');
      if (!q) return;
      if (box) box.value = q;
      status.textContent = `"${q}" 검색 중…`;

      const qLower = q.toLowerCase();
      let total = 0;

      // 기관 / 소식 — 부분 문자열 매칭 (search-index.json).
      try {
        const res = await fetch('/search-index.json');
        const { orgs, notices } = await res.json();

        const orgHits = orgs.filter((org) => org.name.toLowerCase().includes(qLower));
        if (orgHits.length > 0) {
          const wrap = document.getElementById('org-matches');
          const list = document.getElementById('org-results');
          for (const org of orgHits) {
            const li = document.createElement('li');
            const a = document.createElement('a');
            if (org.url) {
              a.href = org.url;
              a.target = '_blank';
              a.rel = 'noopener noreferrer';
              a.textContent = org.name;
              const sr = document.createElement('span');
              sr.className = 'sr-only';
              sr.textContent = ', 공식 사이트, 새 창에서 열림';
              a.appendChild(sr);
            } else {
              a.href = org.tagHref;
              a.textContent = org.name;
            }
            li.appendChild(a);
            list.appendChild(li);
          }
          wrap.hidden = false;
          total += orgHits.length;
        }

        const noticeHits = notices.filter(
          (n) => n.title.toLowerCase().includes(qLower) || n.orgName.toLowerCase().includes(qLower),
        );
        if (noticeHits.length > 0) {
          const wrap = document.getElementById('notice-matches');
          const list = document.getElementById('notice-results');
          for (const n of noticeHits) {
            const li = document.createElement('li');
            const a = document.createElement('a');
            a.href = n.href;
            if (n.external) {
              a.target = '_blank';
              a.rel = 'noopener noreferrer';
              a.textContent = n.title;
              const sr = document.createElement('span');
              sr.className = 'sr-only';
              sr.textContent = ', 원문, 새 창에서 열림';
              a.appendChild(sr);
            } else {
              a.textContent = n.title;
            }
            li.appendChild(a);
            li.append(' · ' + n.orgName);
            list.appendChild(li);
          }
          wrap.hidden = false;
          total += noticeHits.length;
        }
      } catch {
        // 기관/소식 인덱스를 못 불러와도 아래 Pagefind 결과는 계속 시도한다.
      }

      // 관련 페이지 — Pagefind 전문 검색.
      try {
        // pagefind.js는 astro-pagefind의 빌드 후처리 단계에서 생성되는 런타임 전용
        // 경로라 번들러가 정적으로 못 찾는다 — @vite-ignore로 런타임 동적 import 처리.
        const pagefind = await import(/* @vite-ignore */ '/pagefind/pagefind.js');
        const search = await pagefind.search(q);
        const results = await Promise.all(search.results.slice(0, 20).map((r) => r.data()));
        if (results.length > 0) {
          const wrap = document.getElementById('page-matches');
          const list = document.getElementById('page-results');
          for (const r of results) {
            const li = document.createElement('li');
            const a = document.createElement('a');
            a.href = r.url;
            a.textContent = r.meta && r.meta.title ? r.meta.title : r.url;
            li.appendChild(a);
            if (r.meta && r.meta.date) {
              li.append(' · ' + r.meta.date);
            }
            list.appendChild(li);
          }
          wrap.hidden = false;
          total += results.length;
        }
      } catch {
        // Pagefind를 못 불러와도 위 기관/소식 결과는 이미 표시돼 있을 수 있다.
      }

      // 목록을 먼저 채우고 나서 알린다 (role="status" — 결과 도착을 무음으로 두지 않는다).
      status.textContent =
        total > 0
          ? `"${q}" 검색 결과 ${total}건`
          : `"${q}" 검색 결과가 없습니다. 전화로 물어보셔도 됩니다.`;
    })();
    </script>
</BaseLayout>

<style>
  #org-matches,
  #notice-matches,
  #page-matches {
    margin-top: 1.5rem;
  }
</style>
