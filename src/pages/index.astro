---
// 홈 = 허브 (스펙 §1, §5 홈 입구).
import BaseLayout from '../layouts/BaseLayout.astro';
import { MAIN_MENU, PHONE } from '../config';

const links = [{ label: `전화 상담: ${PHONE.display}`, href: `tel:${PHONE.tel}` }];
---

<BaseLayout pageName="홈" links={links}>
  <h2>무엇을 도와드릴까요?</h2>
  <ul class="menu-list">
    {MAIN_MENU.map((item) => (
      <li><a href={item.href}>{item.label}</a></li>
    ))}
  </ul>
</BaseLayout>
