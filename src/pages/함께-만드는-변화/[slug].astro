---
// 함께 만드는 변화: 좋은비전이 직접 수행한 활동·후원으로 만들어진 변화 기록 — 상세 페이지.
// notices(소식)와 분리된 컬렉션. 비공개(draft) 글은 경로 자체를 만들지 않는다.
// 2026-07-21 최종 디자인 반영 — ChangeCard 상세(.change-hero) 스타일.
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { publishedOnly } from '../../lib/impact';

export async function getStaticPaths() {
  const entries = publishedOnly(await getCollection('impact'));
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const isoDate = entry.data.date.toISOString().slice(0, 10);
---

<BaseLayout pageName={entry.data.title}>
  <article>
    <section class="post-head">
      <p><span class="tag">{entry.data.category}</span></p>
      <h1>{entry.data.title}</h1>
      <p class="meta"><time datetime={isoDate} data-pagefind-meta="date[datetime]">{isoDate}</time></p>
    </section>
    <section>
      <img src={entry.data.image} alt={entry.data.image_alt} class="change-hero" />
      <Content />
    </section>
    {entry.data.link && (
      <p>
        관련 링크:{' '}
        <a href={entry.data.link} target="_blank" rel="noopener noreferrer">
          {entry.data.link}<span class="sr-only">, 원문, 새 창에서 열림</span>
        </a>
        <span class="external-link-label" aria-hidden="true">원문 · 새 창</span>
      </p>
    )}
    <p><a href="/함께-만드는-변화/">함께 만드는 변화 목록으로 돌아가기</a></p>
  </article>
</BaseLayout>

<style>
  .change-hero {
    object-fit: contain;
    border: 1px solid var(--line);
    background: #fff;
    border-radius: 0.35rem;
    width: 100%;
    max-height: 42rem;
    display: block;
    margin-bottom: 1rem;
  }
</style>
