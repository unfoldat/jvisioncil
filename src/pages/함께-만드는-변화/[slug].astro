---
// 함께 만드는 변화: 좋은비전이 직접 수행한 활동·후원으로 만들어진 변화 기록 — 상세 페이지.
// notices(소식)와 분리된 컬렉션 (§ CLAUDE.md 지침). 비공개(draft) 글은 경로 자체를 만들지 않는다.
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { publishedOnly } from '../../lib/impact';
import { PHONE } from '../../config';

export async function getStaticPaths() {
  const entries = publishedOnly(await getCollection('impact'));
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const links = [
  { label: '목록으로 돌아가기', href: '/후원안내/#함께-만드는-변화' },
  { label: `전화 상담: ${PHONE.display}`, href: `tel:${PHONE.tel}` },
  { label: '소식', href: '/소식/' },
];
const breadcrumb = [
  { label: '홈', href: '/' },
  { label: '후원안내', href: '/후원안내/' },
];
const isoDate = entry.data.date.toISOString().slice(0, 10);
---

<BaseLayout pageName={entry.data.title} breadcrumb={breadcrumb} links={links}>
  <p>
    <time datetime={isoDate} data-pagefind-meta="date[datetime]">{isoDate}</time>
    {' · '}{entry.data.category}
  </p>
  <img src={entry.data.image} alt={entry.data.image_alt} class="impact-detail-image" />
  <Content />

  {entry.data.link && (
    <p>
      관련 링크:{' '}
      <a href={entry.data.link} target="_blank" rel="noopener">{entry.data.link} (외부 사이트, 새 탭에서 열림)</a>
    </p>
  )}
</BaseLayout>

<style>
  .impact-detail-image {
    max-width: 100%;
    height: auto;
  }
</style>
