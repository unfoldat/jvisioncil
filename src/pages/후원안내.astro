---
// 말단 = 계좌 (§1). 기부금 PDF = 무보관 원칙의 유일한 보관 예외 (§0.1).
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ImpactList from '../components/ImpactList.astro';
import { 태그경로 } from '../lib/notices';
import { sortForList as sortImpactForList } from '../lib/impact';
import { PHONE } from '../config';

const reports = (await getCollection('donation-reports')).sort((a, b) => b.data.year - a.data.year);
const sponsors = (await getCollection('sponsors')).sort((a, b) => a.id.localeCompare(b.id));
const impactEntries = sortImpactForList(await getCollection('impact'));

// §4 — 후원 신뢰의 이중 근거: 기부금 PDF(숫자) + 활동소식(이야기).
const links = [
  { label: '소식 — 좋은비전', href: 태그경로('좋은비전') },
  { label: `전화 상담: ${PHONE.display}`, href: `tel:${PHONE.tel}` },
];
---

<BaseLayout pageName="후원안내" breadcrumb={[{ label: '홈', href: '/' }]} links={links}>
  <h2>후원 계좌</h2>
  {/* ⚠️ 계좌번호 클라이언트 미제공 — 실값 받으면 config로 옮기고 복사 버튼 추가(§2.4). */}
  <p>계좌번호는 준비 중입니다. 전화로 문의해 주세요.</p>

  <h2>기부금 사용내역</h2>
  {reports.length === 0 ? (
    <p>공개된 기부금 사용내역이 아직 없습니다.</p>
  ) : (
    <ul>
      {reports.map((report) => (
        <li><a href={report.data.file}>{report.data.year}년 기부금 사용내역 (PDF)</a></li>
      ))}
    </ul>
  )}

  <h2>후원기관</h2>
  {sponsors.length === 0 ? (
    <p>후원기관 목록은 준비 중입니다.</p>
  ) : (
    <ul>
      {sponsors.map((sponsor) => (
        <li><a href={sponsor.data.url}>{sponsor.data.name}</a></li>
      ))}
    </ul>
  )}

  <h2 id="함께-만드는-변화">함께 만드는 변화</h2>
  <ImpactList entries={impactEntries} empty="아직 등록된 활동 글이 없습니다." />
</BaseLayout>
