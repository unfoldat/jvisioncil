---
// 2026-07-21 최종 디자인 반영. 기부금 PDF = 무보관 원칙의 유일한 보관 예외.
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ImpactList from '../components/ImpactList.astro';
import { sortForList as sortImpactForList } from '../lib/impact';
import { sortForList as sortReportsForList } from '../lib/donationReports';

const impactEntries = sortImpactForList(await getCollection('impact'));
const reports = sortReportsForList(await getCollection('donation-reports'));
const sponsors = (await getCollection('sponsors')).sort((a, b) => a.id.localeCompare(b.id));
---

<BaseLayout pageName="후원 안내">
  <section>
    <small class="review">검토 영역: 후원 소개</small>
    <h1>후원 안내</h1>
    <p class="lead">좋은비전의 상담과 정보 연결 활동이 지속되도록 함께해주세요.</p>
  </section>

  <section aria-labelledby="changes-title">
    <small class="review">검토 영역: 함께 만드는 변화</small>
    <div class="section-head">
      <h2 id="changes-title">함께 만드는 변화</h2>
    </div>
    <p>후원과 참여로 이어진 좋은비전의 활동을 전합니다.</p>
    <ImpactList entries={impactEntries} empty="등록된 활동 이야기가 아직 없습니다." />
  </section>

  <section aria-labelledby="donate-title">
    <small class="review">검토 영역: 후원 안내</small>
    <h2 id="donate-title">후원하기</h2>
    <dl class="facts donate-facts">
      <div><dt>은행</dt><dd>○○은행</dd></div>
      <div><dt>계좌번호</dt><dd>123-456-123456</dd></div>
      <div><dt>예금주</dt><dd>확인 후 입력</dd></div>
    </dl>
  </section>

  <section aria-labelledby="reports-title">
    <h2 id="reports-title">기부금 사용내역</h2>
    {reports.length === 0 ? (
      <p>공개된 기부금 사용내역이 아직 없습니다.</p>
    ) : (
      <ul class="report-board">
        {reports.map((report) => (
          <li>
            {report.data.pinned && (
              <span class="pinned-label"><span aria-hidden="true">📌</span> 상단 고정</span>
            )}
            <a href={report.data.file} download>{report.data.title} PDF 다운로드</a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section aria-labelledby="sponsors-title">
    <h2 id="sponsors-title">후원기관</h2>
    {sponsors.length === 0 ? (
      <p>후원기관 목록은 준비 중입니다.</p>
    ) : (
      <ul>
        {sponsors.map((sponsor) => (
          <li><a href={sponsor.data.url}>{sponsor.data.name}</a></li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  /* 검토 요청: 노란 강조 범위가 너무 넓었음 — 텍스트보다 살짝 여유 있는 정도로 축소.
     이후 요청: 배경은 더 옅게, 계좌 정보(더미 텍스트)는 더 짙고 크게. */
  .donate-facts {
    background: #fffdf2;
    border: 1px solid #ecdea6;
    border-radius: 0.25rem;
    width: fit-content;
    padding: 0.3rem 0.85rem;
  }
  .donate-facts dd {
    color: #1a1a1a;
    font-size: 1.05rem;
    font-weight: 800;
  }

  /* 검토 요청: 보고서가 여러 건 쌓일 예정 — 게시판처럼(소식 목록과 같은 시각 언어). */
  .report-board {
    border-top: 2px solid var(--ink);
    background: #fff;
    padding: 0;
    list-style: none;
  }
  .report-board li {
    border-bottom: 1px solid var(--line);
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 1rem;
    padding: 0.82rem 0.65rem;
    display: flex;
  }
</style>
