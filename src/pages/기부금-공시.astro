---
// 데모 브랜치: 후원안내의 "기부금 사용내역"과 같은 컬렉션을 그대로 보여주는
// 별도 메뉴/페이지. 데이터 원본이 같아 CMS 스키마 변경은 필요 없다.
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { sortForList } from '../lib/donationReports';

const reports = sortForList(await getCollection('donation-reports'));
---

<BaseLayout pageName="기부금 공시">
  <section aria-labelledby="reports-title">
    <small class="review">검토 영역: 기부금 공시</small>
    <h1 id="reports-title">기부금 공시</h1>
    <p class="lead">좋은비전이 받은 후원금을 어떻게 썼는지 공개합니다.</p>
    {reports.length === 0 ? (
      <p>공개된 기부금 사용내역이 아직 없습니다.</p>
    ) : (
      <ul class="report-board">
        {reports.map((report) => (
          <li>
            {report.data.pinned && (
              <span class="pinned-label"><span aria-hidden="true">📌</span> 상단 고정</span>
            )}
            <a href={report.data.file} download>{report.data.title} PDF 다운로드</a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .report-board {
    border-top: 2px solid var(--ink);
    background: #fff;
    padding: 0;
    list-style: none;
  }
  .report-board li {
    border-bottom: 1px solid var(--line);
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 1rem;
    padding: 0.82rem 0.65rem;
    display: flex;
  }
</style>
