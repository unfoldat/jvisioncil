---
// 스펙 §2.2 문서 순서. 배포 후 동결.
import SearchBox from '../components/SearchBox.astro';
import PhoneLink from '../components/PhoneLink.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import PartnerGrid from '../components/PartnerGrid.astro';
import { SITE_NAME, MAIN_MENU, NOINDEX, PHONE, type Link } from '../config';

interface Props {
  pageName: string;
  breadcrumb?: Link[];
  links: Link[];
  // 검색 결과 페이지처럼 자기 자신이 색인되면 안 되는 페이지만 false.
  searchable?: boolean;
}
const { pageName, breadcrumb = [], links, searchable = true } = Astro.props;

// 스펙 §2.7 첫 줄 계약 — 페이지명 선행. h1은 같은 문자열.
const title = `${pageName} – ${SITE_NAME}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {/* 연습 배포 전용. 실도메인 전환 시 config의 NOINDEX만 끈다 (별도 커밋). */}
    {NOINDEX && <meta name="robots" content="noindex" />}
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    {/* ① 검색창 = 페이지 유일의 편집창 ② 전화 — 불변식: F2 → Tab 1회 = 전화 */}
    <header>
      <SearchBox pageName={pageName} />
      <PhoneLink />
    </header>

    <nav aria-label="주 메뉴">
      <ul class="menu-list">
        {MAIN_MENU.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    {/* data-pagefind-body: 본문만 색인. header/footer 보일러플레이트와 /admin 제외. */}
    <main data-pagefind-body={searchable || undefined} data-pagefind-ignore={!searchable || undefined}>
      <h1>{pageName}</h1>
      {breadcrumb.length > 0 && (
        <p>
          {breadcrumb.map((crumb, i) => (
            <>
              {i > 0 && ' > '}
              <a href={crumb.href}>{crumb.label}</a>
            </>
          ))}
          {' > '}{pageName}
        </p>
      )}
      <slot />
      <RelatedLinks links={links} />
    </main>

    <footer>
      <PartnerGrid />
      <p>{SITE_NAME} · 전화 {PHONE.display}</p>
    </footer>
  </body>
</html>

<style is:global>
  /* DOM 순서 = 읽기 순서 = 시각 순서 (스펙 §2.10). 시각 순서만 바꾸는 CSS 금지. */

  /* 대비값은 실제 계산 결과 (WCAG AA 4.5:1 이상):
     text #1a1a1a vs #fff = 17.4:1 / link #0b4fa8 vs #fff = 7.78:1 /
     focus #c6501a vs #fff = 4.60:1 (비텍스트 컴포넌트 기준 3:1 이상 요구, 여유 있게 통과) */
  :root {
    --color-bg: #ffffff;
    --color-text: #1a1a1a;
    --color-link: #0b4fa8;
    --color-link-visited: #5b3a99;
    --color-footer-bg: #f2f4f7;
    --color-focus: #c6501a;
  }

  * {
    box-sizing: border-box;
  }

  html {
    /* 기본 16px 기준 18px — 대리 행위자·고령 이용자 가독성 */
    font-size: 112.5%;
  }

  body {
    margin: 0 auto;
    padding: 1rem;
    max-width: 46rem;
    line-height: 1.7;
    font-family: system-ui, sans-serif;
    color: var(--color-text);
    background: var(--color-bg);
  }

  a {
    color: var(--color-link);
  }
  a:visited {
    color: var(--color-link-visited);
  }

  /* 포커스는 색만이 아니라 굵은 외곽선으로 표시 (Tab 이동 추적성). */
  a:focus-visible,
  input:focus-visible {
    outline: 3px solid var(--color-focus);
    outline-offset: 2px;
  }

  h1 {
    font-size: 1.6rem;
    line-height: 1.35;
  }
  h2 {
    font-size: 1.2rem;
    line-height: 1.35;
    margin-top: 2rem;
  }

  /* 터치 타겟 44px 이상 — 독립된 메뉴/목록 항목에 적용.
     문장 안에 섞인 링크(브레드크럼, 본문 링크)는 WCAG 타겟 크기 규정의
     인라인 예외 대상이라 제외한다. */
  .menu-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .menu-list a {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.5rem 0.9rem;
    text-decoration: underline;
  }

  input[type='search'] {
    min-height: 44px;
    font-size: 1rem;
    padding: 0.4rem 0.6rem;
  }

  footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid #ccc;
    background: var(--color-footer-bg);
  }
</style>
