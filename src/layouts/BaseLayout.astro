---
// 2026-07-21 최종 디자인 반영(전면 개편) — 독수리 검토 목업(좋은비전_최종_홈.html +
// 좋은비전_최종_정적사이트.zip) 이식. "검토 영역" 표시는 내일 시연·피드백 수집용으로
// 의도적으로 유지한다 — 임의로 지우지 않는다.
import { SITE_NAME, SITE_DESCRIPTION, ORG_FULL_NAME, MAIN_MENU, FOOTER_MENU, NOINDEX, PHONE, ADDRESS_PLACEHOLDER, EMAIL_PLACEHOLDER } from '../config';

interface Props {
  pageName: string;
  // 검색 결과 페이지처럼 자기 자신이 색인되면 안 되는 페이지만 false.
  searchable?: boolean;
}
const { pageName, searchable = true } = Astro.props;

const title = `${pageName} – ${SITE_NAME}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {NOINDEX && <meta name="robots" content="noindex" />}
    <title>{title}</title>
    <meta name="description" content={SITE_DESCRIPTION} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <a href="#main-content" class="skip">본문으로 바로가기</a>

    <header class="site-header">
      <div class="head wrap">
        <small class="review">검토 영역: 헤더</small>
        <a class="brand" href="/" aria-label={`${SITE_NAME} CIL 홈`}>
          <span class="logo-slot" aria-hidden="true">공식<br />로고</span>
          <span><strong>{SITE_NAME} CIL</strong><span>{ORG_FULL_NAME}</span></span>
        </a>
      </div>
      <div class="menu-band">
        <nav class="primary-nav wrap" aria-label="주 메뉴">
          <small class="review">검토 영역: 주 메뉴</small>
          <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="main-menu">☰ 주 메뉴 열기</button>
          <ul id="main-menu" class="nav-list">
            {MAIN_MENU.map((item) => (
              <li><a href={item.href} aria-current={path === item.href ? 'page' : undefined}>{item.label}</a></li>
            ))}
          </ul>
        </nav>
      </div>
      <div class="assist-tools">
        <div class="assist-grid wrap">
          <section aria-labelledby="search-title">
            <small class="review">검토 영역: 검색 및 이동</small>
            <h2 id="search-title" class="tool-title">검색 및 이동</h2>
            <form class="search-form" action="/검색/" method="get" role="search">
              <div>
                <label for="site-search">페이지, 소식, 기관 또는 기능 검색</label>
                <input id="site-search" type="search" name="q" required />
              </div>
              <button type="submit">검색</button>
            </form>
            <p id="search-hub-status" class="sr-only" aria-live="polite"></p>
          </section>
          <section class="zoom" aria-labelledby="zoom-title">
            <small class="review">검토 영역: 글자 크기 조절</small>
            <h2 id="zoom-title" class="tool-title">글자 배율</h2>
            <div class="zoom-row">
              <button type="button" data-zoom="down">축소</button>
              <input id="zoom-range" type="range" min="80" max="500" step="10" value="100" aria-label="글자 배율, 80퍼센트에서 500퍼센트" />
              <button type="button" data-zoom="up">확대</button>
              <button type="button" data-zoom="reset">100%</button>
              <output id="zoom-output" for="zoom-range">100%</output>
            </div>
            <p id="zoom-status" class="sr-only" aria-live="polite"></p>
          </section>
        </div>
      </div>
    </header>

    <main id="main-content" class="main wrap" tabindex="-1" data-pagefind-body={searchable || undefined} data-pagefind-ignore={!searchable || undefined}>
      <slot />
    </main>

    <footer class="footer">
      <div class="wrap">
        <small class="review">검토 영역: 푸터</small>
        <p><strong>{ORG_FULL_NAME}</strong></p>
        <address>주소: {ADDRESS_PLACEHOLDER}<br />연락처: {PHONE.display} · 이메일: {EMAIL_PLACEHOLDER}</address>
        <nav aria-label="푸터 메뉴">
          {FOOTER_MENU.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </div>
    </footer>

    <script>
      (() => {
        const root = document.documentElement;
        const range = document.getElementById('zoom-range') as HTMLInputElement;
        const output = document.getElementById('zoom-output') as HTMLOutputElement;
        const status = document.getElementById('zoom-status') as HTMLParagraphElement;
        const apply = (value: number | string, announce = false) => {
          const next = Math.max(80, Math.min(500, Number(value) || 100));
          root.style.setProperty('--zoom', String(next / 100));
          root.dataset.zoom = next >= 180 ? 'wide' : '';
          range.value = String(next);
          output.textContent = `${next}%`;
          localStorage.setItem('goodvision-zoom', String(next));
          if (announce) status.textContent = `글자 배율 ${next}퍼센트`;
        };
        apply(localStorage.getItem('goodvision-zoom') || 100);
        range.addEventListener('input', () => apply(range.value, true));
        document.querySelectorAll('[data-zoom]').forEach((button) =>
          button.addEventListener('click', () => {
            const zoomAction = (button as HTMLElement).dataset.zoom;
            if (zoomAction === 'reset') apply(100, true);
            else apply(Number(range.value) + (zoomAction === 'up' ? 10 : -10), true);
          }),
        );

        const toggle = document.querySelector('.menu-toggle') as HTMLButtonElement;
        const menu = document.getElementById('main-menu') as HTMLUListElement;
        const narrow = () => matchMedia('(max-width: 880px)').matches || Number(range.value) >= 180;
        const closeMenu = (focus = false) => {
          toggle.setAttribute('aria-expanded', 'false');
          toggle.textContent = '☰ 주 메뉴 열기';
          menu.classList.remove('open');
          if (narrow()) menu.hidden = true;
          if (focus) toggle.focus();
        };
        const syncMenu = () => {
          if (narrow()) closeMenu();
          else {
            menu.hidden = false;
            toggle.setAttribute('aria-expanded', 'false');
          }
        };
        toggle.addEventListener('click', () => {
          const open = toggle.getAttribute('aria-expanded') === 'true';
          if (open) closeMenu(true);
          else {
            menu.hidden = false;
            menu.classList.add('open');
            toggle.setAttribute('aria-expanded', 'true');
            toggle.textContent = '주 메뉴 닫기';
            menu.querySelector('a')?.focus();
          }
        });
        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') closeMenu(true);
        });
        addEventListener('resize', syncMenu);
        range.addEventListener('input', syncMenu);
        syncMenu();

        document.addEventListener('keydown', (event) => {
          const tag = (event.target as HTMLElement)?.tagName?.toLowerCase();
          if (event.key === 'F2' && tag !== 'input' && tag !== 'textarea') {
            event.preventDefault();
            document.getElementById('site-search')?.focus();
            const message = document.getElementById('search-hub-status');
            if (message) message.textContent = '검색 및 이동 창입니다. 페이지, 소식, 기관 또는 기능을 검색할 수 있습니다.';
          }
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --zoom: 1;
    --bg: #fbfaf5;
    --paper: #fff;
    --ink: #1f241f;
    --muted: #62685f;
    --line: #dedbd0;
    --green: #3f6d35;
    --green2: #eaf3e6;
    --gold: #f4dfaa;
    --violet: #5f5571;
    --violet2: #eeeaf4;
    --red: #8b3f26;
    font-size: calc(100% * var(--zoom));
  }
  * {
    box-sizing: border-box;
  }
  html {
    scroll-behavior: smooth;
  }
  body {
    background: var(--bg);
    color: var(--ink);
    margin: 0;
    font-family: Arial, 'Noto Sans KR', system-ui, sans-serif;
    line-height: 1.68;
  }
  a {
    color: #234f1f;
    text-underline-offset: 0.18em;
    text-decoration-thickness: 0.11em;
  }
  button,
  input {
    font: inherit;
  }
  button,
  .btn {
    border: 1.5px solid var(--ink);
    background: var(--paper);
    color: var(--ink);
    cursor: pointer;
    border-radius: 0.35rem;
    min-height: 2.5rem;
    padding: 0.46rem 0.75rem;
    font-weight: 750;
  }
  .btn {
    background: var(--green);
    border-color: var(--green);
    color: #fff;
    justify-content: center;
    align-items: center;
    text-decoration: none;
    display: inline-flex;
  }
  .btn.alt {
    background: var(--violet);
    border-color: var(--violet);
  }
  button:hover,
  .btn:hover,
  a:hover {
    text-decoration: underline;
  }
  :focus-visible {
    outline: 0.22rem solid var(--red);
    outline-offset: 0.18rem;
  }
  .wrap {
    width: min(74rem, 100% - 2rem);
    margin: auto;
  }
  .skip {
    z-index: 30;
    background: #fff;
    padding: 0.8rem;
    position: absolute;
    top: -8rem;
    left: 1rem;
  }
  .skip:focus {
    top: 1rem;
  }
  .review {
    color: #666b63;
    width: max-content;
    max-width: 100%;
    margin: 0 0 0.45rem;
    font-size: 0.76rem;
    font-weight: 650;
    display: block;
  }
  .site-header {
    border-bottom: 1px solid var(--line);
    background: #fff;
  }
  .head {
    padding: 1rem 0 0.8rem;
  }
  .brand {
    width: max-content;
    max-width: 100%;
    color: var(--ink);
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    display: flex;
  }
  .logo-slot {
    border: 2px solid var(--green);
    width: 3.3rem;
    min-width: 3.3rem;
    height: 3.3rem;
    color: var(--green);
    text-align: center;
    border-radius: 0.7rem;
    place-items: center;
    font-size: 0.76rem;
    font-weight: 850;
    line-height: 1.1;
    display: grid;
  }
  .brand strong {
    font-size: 1.35rem;
    line-height: 1.1;
    display: block;
  }
  .brand span span {
    color: var(--muted);
    font-size: 0.92rem;
    display: block;
  }
  .menu-band {
    border-top: 1px solid var(--line);
    background: #f3f5ee;
    border-bottom: 2px solid #c7cabc;
  }
  .primary-nav {
    padding: 0.55rem 0 0.2rem;
  }
  .nav-list {
    flex-wrap: nowrap;
    align-items: stretch;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
  }
  .nav-list li {
    display: flex;
  }
  .nav-list a {
    min-height: 2.75rem;
    color: var(--ink);
    border-bottom: 0.28rem solid transparent;
    align-items: center;
    padding: 0.35rem 1rem;
    font-weight: 760;
    text-decoration: none;
    display: flex;
  }
  .nav-list a:hover {
    background: #fff;
    text-decoration: underline;
  }
  .nav-list a[aria-current='page'] {
    border-bottom-color: var(--green);
    background: #fff;
    font-weight: 900;
  }
  .menu-toggle {
    display: none;
  }
  .assist-tools {
    border-bottom: 1px solid var(--line);
    background: #fff;
  }
  .assist-grid {
    grid-template-columns: minmax(18rem, 1fr) minmax(20rem, 0.95fr);
    align-items: start;
    gap: 1.75rem;
    padding: 0.9rem 0 1rem;
    display: grid;
  }
  .tool-title {
    margin: 0 0 0.22rem;
    font-size: 0.83rem;
  }
  .search-form {
    max-width: 28rem;
    display: flex;
  }
  .search-form label {
    margin-bottom: 0.22rem;
    font-size: 0.83rem;
    font-weight: 800;
    display: block;
  }
  .search-form > div {
    flex: 1;
  }
  .search-form input {
    border: 1px solid #767676;
    border-radius: 0.25rem 0 0 0.25rem;
    width: 100%;
    min-height: 2.3rem;
    padding: 0.25rem 0.45rem;
  }
  .search-form button {
    border-left: 0;
    border-radius: 0 0.25rem 0.25rem 0;
    min-height: 2.3rem;
    padding: 0.2rem 0.6rem;
    font-size: 0.84rem;
  }
  .zoom {
    border-left: 1px solid var(--line);
    padding-left: 1.4rem;
  }
  .zoom-row {
    grid-template-columns: auto minmax(7rem, 1fr) auto auto auto;
    align-items: center;
    gap: 0.35rem;
    display: grid;
  }
  .zoom-row input {
    width: 100%;
    accent-color: var(--green);
  }
  .zoom-row button {
    min-height: 2.2rem;
    padding: 0.12rem 0.42rem;
    font-size: 0.82rem;
  }
  .zoom-row output {
    white-space: nowrap;
    font-size: 0.83rem;
    font-weight: 850;
  }
  .main {
    padding: 2rem 0 4.5rem;
  }
  .main > section,
  .main > article > section {
    overflow-wrap: anywhere;
    margin-bottom: 3.3rem;
  }
  h1,
  h2,
  h3 {
    text-wrap: balance;
    line-height: 1.25;
  }
  h1 {
    letter-spacing: -0.035em;
    font-size: clamp(2rem, 4.8vw, 4rem);
  }
  h2 {
    font-size: clamp(1.45rem, 3vw, 2.35rem);
  }
  h3 {
    font-size: 1.18rem;
  }
  .lead {
    max-width: 52rem;
    font-size: 1.13rem;
  }
  .eyebrow {
    color: var(--green);
    font-weight: 850;
  }
  .grid {
    gap: 1rem;
    display: grid;
  }
  .two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .card {
    border: 1px solid var(--line);
    background: #fff;
    border-radius: 0.35rem;
    padding: 1.2rem;
  }
  .card.green {
    border-top: 0.45rem solid var(--green);
  }
  .card.violet {
    border-top: 0.45rem solid var(--violet);
  }
  .card.gold {
    border-top: 0.45rem solid #bc8f28;
  }
  .actions {
    flex-wrap: wrap;
    gap: 0.65rem;
    display: flex;
  }
  .home-summary {
    padding: 0.45rem 0 1rem;
  }
  .home-summary h1 {
    max-width: 58rem;
    margin: 0.25rem 0 0.55rem;
    font-size: clamp(1.8rem, 3.6vw, 3rem);
  }
  .journey-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }
  .journey-card {
    border: 1px solid var(--line);
    border-top: 0.42rem solid var(--green);
    background: #fff;
    border-radius: 0.35rem;
    flex-direction: column;
    min-height: 13rem;
    padding: 1.25rem;
    display: flex;
  }
  .journey-card p {
    flex: 1;
  }
  .journey-card a {
    font-weight: 850;
  }
  .section-head {
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
    display: flex;
  }
  .section-head h2 {
    margin-bottom: 0.3rem;
  }
  .counsel {
    background: var(--green2);
    border-left: 0.55rem solid var(--green);
    border-radius: 0.25rem;
    padding: 2rem;
  }
  .slogan {
    background: var(--green);
    color: #fff;
    border-radius: 0.25rem;
    padding: 2.2rem;
  }
  .facts {
    gap: 0;
    margin: 1rem 0;
    display: grid;
  }
  .facts div {
    border-top: 1px solid var(--line);
    grid-template-columns: minmax(9rem, 14rem) 1fr;
    gap: 1rem;
    padding: 0.75rem 0;
    display: grid;
  }
  .facts dt {
    font-weight: 850;
  }
  .facts dd {
    margin: 0;
  }
  .profile-grid {
    grid-template-columns: minmax(12rem, 0.35fr) minmax(0, 1fr);
    align-items: start;
    gap: 1.4rem;
    display: grid;
  }
  .profile-photo,
  .photo-slot {
    border: 1px solid var(--line);
    text-align: center;
    min-height: 15rem;
    color: var(--muted);
    background: linear-gradient(135deg, #fff, #e9f2e5);
    place-items: center;
    padding: 1rem;
    font-weight: 850;
    display: grid;
  }
  .support-box {
    background: #fff9e6;
    border: 1px solid #dfc983;
    padding: 1.4rem;
  }
  .tag,
  .pinned-label,
  .external-link-label {
    border: 1px solid;
    border-radius: 99rem;
    padding: 0.13rem 0.5rem;
    font-size: 0.84rem;
    font-weight: 850;
    display: inline-block;
  }
  .pinned-label {
    background: var(--gold);
    color: #604715;
  }
  .external-link-label {
    background: var(--violet2);
    color: var(--violet);
  }
  .meta {
    color: var(--muted);
    font-size: 0.92rem;
  }
  .post-head {
    border-bottom: 1px solid var(--line);
    padding-bottom: 1.3rem;
  }
  .post-head h1 {
    font-size: clamp(1.9rem, 4vw, 3.2rem);
  }
  .footer {
    border-top: 2px solid var(--ink);
    background: #e9e6da;
    padding: 2.5rem 0;
  }
  .footer address {
    font-style: normal;
  }
  .footer nav {
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1rem;
    display: flex;
  }
  .sr-only {
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    position: absolute;
    overflow: hidden;
  }
  @media (width <= 950px) {
    .journey-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (width <= 880px) {
    .menu-toggle {
      display: inline-flex;
    }
    .nav-list {
      display: none;
    }
    .nav-list.open {
      border: 1px solid var(--line);
      background: #fff;
      margin-top: 0.55rem;
      display: grid;
    }
    .nav-list.open li {
      display: block;
    }
    .nav-list.open a {
      border-bottom: 1px solid var(--line);
      min-height: 3rem;
      padding: 0.75rem 0.9rem;
      display: block;
    }
    .assist-grid {
      grid-template-columns: 1fr;
    }
    .zoom {
      border-left: 0;
      border-top: 1px solid var(--line);
      padding-top: 0.8rem;
      padding-left: 0;
    }
  }
  @media (width <= 640px) {
    .wrap {
      width: calc(100% - 1rem);
    }
    .two,
    .three,
    .journey-grid,
    .profile-grid {
      grid-template-columns: 1fr;
    }
    .journey-card {
      min-height: 0;
    }
    .facts div {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }
    .section-head {
      display: block;
    }
    .zoom-row {
      grid-template-columns: 1fr 1fr;
    }
    .zoom-row input,
    .zoom-row output {
      grid-column: 1 / -1;
    }
    .actions {
      flex-direction: column;
    }
  }
  html[data-zoom='wide'] .menu-toggle {
    display: inline-flex;
  }
  html[data-zoom='wide'] .nav-list {
    display: none;
  }
  html[data-zoom='wide'] .nav-list.open {
    border: 1px solid var(--line);
    background: #fff;
    margin-top: 0.55rem;
    display: grid;
  }
  html[data-zoom='wide'] .nav-list.open li {
    display: block;
  }
  html[data-zoom='wide'] .nav-list.open a {
    border-bottom: 1px solid var(--line);
    min-height: 3rem;
    padding: 0.75rem 0.9rem;
    display: block;
  }
  html[data-zoom='wide'] .assist-grid,
  html[data-zoom='wide'] .two,
  html[data-zoom='wide'] .three,
  html[data-zoom='wide'] .journey-grid,
  html[data-zoom='wide'] .profile-grid {
    grid-template-columns: 1fr;
  }
  html[data-zoom='wide'] .zoom {
    border-left: 0;
    border-top: 1px solid var(--line);
    padding-top: 0.8rem;
    padding-left: 0;
  }
</style>
