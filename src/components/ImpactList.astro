---
// 2026-07-21 최종 디자인 반영 — ChangeCard 목록 래퍼(후원안내 카드 섹션 + 함께 만드는 변화 전체 목록 공용).
import type { CollectionEntry } from 'astro:content';
import ChangeCard from './ChangeCard.astro';

interface Props {
  entries: CollectionEntry<'impact'>[];
  empty: string;
}
const { entries, empty } = Astro.props;
---

{entries.length === 0 ? (
  <p>{empty}</p>
) : (
  <div class="change-list">
    {entries.map((entry) => <ChangeCard entry={entry} />)}
  </div>
)}

<style>
  .change-list {
    gap: 1rem;
    display: grid;
  }
</style>
