---
import type { CollectionEntry } from 'astro:content';
import { impactPath } from '../lib/impact';

interface Props {
  entries: CollectionEntry<'impact'>[];
  empty: string;
}
const { entries, empty } = Astro.props;
const iso = (d: Date) => d.toISOString().slice(0, 10);
---

{entries.length === 0 ? (
  <p>{empty}</p>
) : (
  <ul class="impact-list">
    {entries.map((entry) => (
      <li>
        <a href={impactPath(entry)} class="impact-card">
          <img src={entry.data.image} alt={entry.data.image_alt} loading="lazy" />
          <span class="impact-card-title">{entry.data.title}</span>
          <time datetime={iso(entry.data.date)}>{iso(entry.data.date)}</time>
          <span class="impact-card-summary">{entry.data.summary}</span>
        </a>
      </li>
    ))}
  </ul>
)}

<style>
  .impact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: 1rem;
  }
  .impact-card {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-height: 44px;
    padding: 0.5rem;
    border: 1px solid #ccc;
  }
  .impact-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
  .impact-card-title {
    font-weight: bold;
  }
</style>
