---
import { RELATED_HEADING, type Link } from '../config';

interface Props {
  links: Link[];
}
const { links } = Astro.props;

// 스펙 §4 — 막다른 페이지 0개. 빌드 시점에 깨뜨린다.
if (!links || links.length === 0) {
  throw new Error(`막다른 페이지 금지: 전이표가 비었습니다 — ${Astro.url.pathname}`);
}
---

<h2>{RELATED_HEADING}</h2>
<ul class="related-list">
  {links.map((link) => (
    <li><a href={link.href}>{link.label}</a></li>
  ))}
</ul>

<style>
  /* 라벨 길이가 제각각이라(전화번호~기관명) 칩 대신 세로 목록, 터치 타겟 44px 이상. */
  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .related-list li {
    margin-bottom: 0.25rem;
  }
  .related-list a {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.4rem 0.2rem;
  }
</style>
