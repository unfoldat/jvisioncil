---
import { PHONE, PHONE_NOTE } from '../config';
---

<a class="phone-link" href={`tel:${PHONE.tel}`}>전화 상담: {PHONE.display}</a>
<p>{PHONE_NOTE}</p>

<style>
  /* F2 → Tab 1회 = 전화 (불변식). 헤더의 핵심 행동 말단이라 터치 타겟을 넉넉히. */
  .phone-link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.5rem 0.9rem;
    font-weight: bold;
  }
</style>
