---
// 협력기관 배너 그리드 (2026-07-21 최종 디자인 반영) — 기관소개/홈 본문에 배치.
// 배지 클릭 = 기관 홈페이지 직행, 새 탭. url 없으면 링크 없이 텍스트만.
// internal(좋은비전 자체 등)은 협력기관이 아니므로 여기엔 나오지 않는다 — partnerOrgs()가 걸러낸다.
import { partnerOrgs } from '../lib/networkOrgs';

interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;

const orgs = await partnerOrgs();
---

<div class:list={['partner-banners', { compact }]}>
  {orgs.map((org) => (
    org.data.url ? (
      <a class="partner-banner" href={org.data.url} target="_blank" rel="noopener noreferrer">
        {org.data.name}<span class="sr-only">, 공식 사이트, 새 창에서 열림</span>
      </a>
    ) : (
      <span class="partner-banner">{org.data.name}<small>공식 주소 확인 중</small></span>
    )
  ))}
</div>

<style>
  .partner-banners {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.65rem;
    display: grid;
  }
  .partner-banner {
    border: 1px solid var(--line);
    min-height: 5rem;
    color: var(--ink);
    text-align: center;
    background: #fff;
    border-radius: 0.35rem;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 0.7rem;
    font-weight: 850;
    text-decoration: none;
    display: flex;
  }
  .partner-banner:hover {
    background: var(--green2);
  }
  .partner-banner small {
    color: var(--muted);
    font-weight: 400;
    display: block;
  }
  @media (width <= 950px) {
    .partner-banners {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (width <= 640px) {
    .partner-banners {
      grid-template-columns: 1fr;
    }
  }
  html[data-zoom='wide'] .partner-banners {
    grid-template-columns: 1fr;
  }
</style>
