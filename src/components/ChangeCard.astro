---
// 2026-07-21 최종 디자인 반영 — "함께 만드는 변화"(impact 컬렉션) 카드.
// 컬렉션 스키마(category 단일값·image_alt·status)는 기존 것을 그대로 유지한다.
import type { CollectionEntry } from 'astro:content';
import { impactPath } from '../lib/impact';

interface Props {
  entry: CollectionEntry<'impact'>;
}
const { entry } = Astro.props;
const iso = (d: Date) => d.toISOString().slice(0, 10);
---

<article class="change-card">
  <span class="change-image">
    <img src={entry.data.image} alt={entry.data.image_alt} loading="lazy" />
  </span>
  <span class="change-copy">
    <h3><a href={impactPath(entry)}>{entry.data.title}</a></h3>
    <p class="meta"><time datetime={iso(entry.data.date)}>{iso(entry.data.date)}</time></p>
    <p>{entry.data.summary}</p>
    <ul class="change-tags">
      <li class="tag">{entry.data.category}</li>
    </ul>
  </span>
</article>

<style>
  .change-card {
    border: 1px solid var(--line);
    background: #fff;
    border-radius: 0.35rem;
    grid-template-columns: minmax(10rem, 0.42fr) minmax(0, 1fr);
    gap: 1rem;
    display: grid;
    overflow: hidden;
  }
  .change-image {
    background: var(--green2);
    min-height: 12rem;
    display: block;
  }
  .change-image img {
    object-fit: cover;
    width: 100%;
    height: 100%;
    display: block;
  }
  .change-copy {
    padding: 1rem;
  }
  .change-copy h3 {
    margin: 0.25rem 0;
  }
  .change-tags {
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
  }
  @media (width <= 640px) {
    .change-card {
      grid-template-columns: 1fr;
    }
    .change-image {
      min-height: 10rem;
    }
  }
  html[data-zoom='wide'] .change-card {
    grid-template-columns: 1fr;
  }
</style>
