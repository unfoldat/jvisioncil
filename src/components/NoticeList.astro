---
// 2026-07-21 최종 디자인 반영 — 홈의 "최근 소식"(article 목록)과 소식 목록/태그 페이지
// (데스크톱 table + 좁은 화면·글자 확대 시 mobile-list)가 이 한 컴포넌트에서 갈린다.
import type { CollectionEntry } from 'astro:content';
import { noticeHref, noticeOrgDisplay } from '../lib/notices';
import { orgMap } from '../lib/networkOrgs';

interface Props {
  notices: CollectionEntry<'notices'>[];
  variant?: 'home' | 'table';
  empty: string;
}
const { notices, variant = 'table', empty } = Astro.props;
const iso = (d: Date) => d.toISOString().slice(0, 10);
// 기관명이 바뀌어도 이 목록은 항상 network-orgs 최신값을 그대로 보여준다(참조 기반 렌더링).
const orgs = await orgMap();
const items = notices.map((notice) => {
  const org = noticeOrgDisplay(notice, orgs);
  return {
    ...noticeHref(notice),
    title: notice.data.title,
    orgName: org.name,
    orgUrl: org.url,
    date: notice.data.date,
    pinned: notice.data.pinned,
  };
});
---

{items.length === 0 ? (
  <p>{empty}</p>
) : variant === 'home' ? (
  <div class="home-news">
    {items.map((item) => (
      <article>
        <div>
          {item.pinned && (
            <span class="pinned-label"><span aria-hidden="true">📌</span> 상단 고정</span>
          )}
          {item.orgUrl ? (
            <a class="tag" href={item.orgUrl} target="_blank" rel="noopener noreferrer">
              {item.orgName}<span class="sr-only">, 공식 사이트, 새 창에서 열림</span>
            </a>
          ) : (
            <span class="tag">{item.orgName}</span>
          )}
          <h3>
            {item.external ? (
              <a href={item.href} target="_blank" rel="noopener noreferrer">
                {item.title}<span class="sr-only">, 원문, 새 창에서 열림</span>
              </a>
            ) : (
              <a href={item.href}>{item.title}</a>
            )}
          </h3>
          {item.external && <span class="external-link-label" aria-hidden="true">원문 · 새 창</span>}
        </div>
        <p class="meta">{item.orgName} · <time datetime={iso(item.date)}>{iso(item.date)}</time></p>
      </article>
    ))}
  </div>
) : (
  <>
    <table class="news-table">
      <thead>
        <tr>
          <th scope="col">기관</th>
          <th scope="col">제목</th>
          <th scope="col">날짜</th>
        </tr>
      </thead>
      <tbody>
        {items.map((item) => (
          <tr>
            <td>
              {item.pinned && (
                <span class="pinned-label"><span aria-hidden="true">📌</span> 상단 고정</span>
              )}
              {item.orgUrl ? (
                <a class="tag" href={item.orgUrl} target="_blank" rel="noopener noreferrer">
                  {item.orgName}<span class="sr-only">, 공식 사이트, 새 창에서 열림</span>
                </a>
              ) : (
                <span class="tag">{item.orgName}</span>
              )}
            </td>
            <td>
              {item.external ? (
                <>
                  <a href={item.href} target="_blank" rel="noopener noreferrer">
                    {item.title}<span class="sr-only">, 원문, 새 창에서 열림</span>
                  </a>
                  <span class="external-link-label" aria-hidden="true">원문 · 새 창</span>
                </>
              ) : (
                <a href={item.href}>{item.title}</a>
              )}
            </td>
            <td><time datetime={iso(item.date)}>{iso(item.date)}</time></td>
          </tr>
        ))}
      </tbody>
    </table>
    <div class="mobile-list">
      {items.map((item) => (
        <article class="mobile-post">
          <p>
            {item.pinned && (
              <span class="pinned-label"><span aria-hidden="true">📌</span> 상단 고정</span>
            )}
            {item.orgUrl ? (
              <a class="tag" href={item.orgUrl} target="_blank" rel="noopener noreferrer">
                {item.orgName}<span class="sr-only">, 공식 사이트, 새 창에서 열림</span>
              </a>
            ) : (
              <span class="tag">{item.orgName}</span>
            )}
          </p>
          <h2>
            {item.external ? (
              <a href={item.href} target="_blank" rel="noopener noreferrer">
                {item.title}<span class="sr-only">, 원문, 새 창에서 열림</span>
              </a>
            ) : (
              <a href={item.href}>{item.title}</a>
            )}
          </h2>
          {item.external && <span class="external-link-label" aria-hidden="true">원문 · 새 창</span>}
          <p class="meta"><time datetime={iso(item.date)}>{iso(item.date)}</time></p>
        </article>
      ))}
    </div>
  </>
)}

<style>
  .home-news {
    border-top: 2px solid var(--ink);
    background: #fff;
  }
  .home-news article {
    border-bottom: 1px solid var(--line);
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.4rem 1rem;
    padding: 0.75rem;
    display: grid;
  }
  .home-news h3 {
    margin: 0.25rem 0;
    font-size: 1.03rem;
  }
  .home-news .meta {
    white-space: nowrap;
  }
  .news-table {
    border-collapse: collapse;
    border-top: 2px solid var(--ink);
    background: #fff;
    width: 100%;
  }
  .news-table th,
  .news-table td {
    border-bottom: 1px solid var(--line);
    text-align: left;
    vertical-align: top;
    padding: 0.82rem 0.65rem;
  }
  .news-table th {
    color: #4d524b;
    background: #f6f4ec;
    font-size: 0.9rem;
  }
  .mobile-list {
    display: none;
  }
  .mobile-post {
    border: 1px solid var(--line);
    background: #fff;
    padding: 1rem;
  }
  .mobile-post h2 {
    font-size: 1.12rem;
  }
  .pinned-label,
  .external-link-label {
    margin-right: 0.3rem;
  }
  @media (width <= 640px) {
    .news-table {
      display: none;
    }
    .mobile-list {
      gap: 0.8rem;
      display: grid;
    }
    .home-news article {
      grid-template-columns: 1fr;
    }
    .home-news .meta {
      white-space: normal;
    }
  }
  html[data-zoom='wide'] .news-table {
    display: none;
  }
  html[data-zoom='wide'] .mobile-list {
    gap: 0.8rem;
    display: grid;
  }
</style>
