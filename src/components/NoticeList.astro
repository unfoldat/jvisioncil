---
import type { CollectionEntry } from 'astro:content';
import { noticeLink } from '../lib/notices';

interface Props {
  notices: CollectionEntry<'notices'>[];
  empty: string;
}
const { notices, empty } = Astro.props;
// 정렬은 호출부(lib/notices.ts의 sortForList)에서 끝내고 넘어온다 — 여기서는 순서를 안 바꾼다.
const items = notices.map((notice) => ({
  ...noticeLink(notice),
  date: notice.data.date,
  pinned: notice.data.pinned,
}));
const iso = (d: Date) => d.toISOString().slice(0, 10);
---

{items.length === 0 ? (
  <p>{empty}</p>
) : (
  <ul class="notice-list">
    {items.map((item) => (
      <li>
        {item.pinned && <strong class="pinned-badge">[공지]</strong>}
        {item.external ? (
          <a href={item.href} target="_blank" rel="noopener">{item.label}</a>
        ) : (
          <a href={item.href}>{item.label}</a>
        )}
        {' · '}<time datetime={iso(item.date)}>{iso(item.date)}</time>
      </li>
    ))}
  </ul>
)}

<style>
  .notice-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .notice-list li {
    margin-bottom: 0.25rem;
  }
  .notice-list a {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.4rem 0.2rem;
  }
  .pinned-badge {
    margin-right: 0.3rem;
  }
</style>
